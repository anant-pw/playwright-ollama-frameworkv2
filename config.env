# config.env — AI QA Framework Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Quick start (pilot-safe settings):
#   1. Set TARGET_URLS to your site
#   2. Set OLLAMA_MODEL to match 'ollama list' output
#   3. Set LOGIN_EMAIL/PASSWORD if site needs login
#   4. Run: python run_smart.py
# ─────────────────────────────────────────────────────────────────────────────

# ── Target URLs ───────────────────────────────────────────────────────────────
TARGET_URLS=https://www.saucedemo.com,http://www.itsecgames.com/

# ── Autonomy Level ────────────────────────────────────────────────────────────
# 1 = Manual    — run pre-written stories only, NO AI calls
# 2 = Semi-Auto — AI navigation + TC gen + signal-gated bug detection (RECOMMENDED)
# 3 = Full Auto — everything including visual detection + AI URL ranking
AUTONOMY_LEVEL=3

# ── Browser ───────────────────────────────────────────────────────────────────
HEADLESS=true
BROWSER=chromium
MAX_STEPS=3
PAGE_TIMEOUT=60000

# ── Stealth ───────────────────────────────────────────────────────────────────
STEALTH_MODE=true
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800
LOCALE=en-US
TIMEZONE=America/New_York

# ── Parallel Agents ───────────────────────────────────────────────────────────
# Start with 1 for pilot stability. Each agent = ~600MB browser + shared Ollama.
# For 16GB RAM: PARALLEL_AGENTS=2 is safe. PARALLEL_AGENTS=3 requires testing.
PARALLEL_AGENTS=2

# ── Smart Crawling ────────────────────────────────────────────────────────────
MAX_CRAWL_PAGES=3
MAX_CRAWL_DEPTH=2

# ── Login ─────────────────────────────────────────────────────────────────────
LOGIN_EMAIL=standard_user
LOGIN_PASSWORD=secret_sauce

# ── Ollama ────────────────────────────────────────────────────────────────────
# Run 'ollama list' to see installed models.
# Memory usage guide:
#   llama3.2   = ~1.4GB (recommended for 16GB RAM)
#   llama3     = ~4.7GB (good quality, heavier)
#   phi3:mini  = ~2.3GB (fast, good for TC gen)
#   mistral    = ~4.1GB
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_READ_TIMEOUT=300
OLLAMA_CONNECT_TIMEOUT=5
OLLAMA_RETRIES=1

# ── Self-Healing ──────────────────────────────────────────────────────────────
# true  = Exploratory mode: tries 5 fallback strategies to find elements
#         Good for AI agent navigation — keeps exploring even if selector shifts
#         Downside: always "passes" even if exact element not found
# false = Strict mode: exact match only — fails if element not found
#         Good for regression stories where selector precision matters
SELF_HEALING=true
# Caches TC generation and navigation decisions by URL hash.
# Same page visited again = instant response, no LLM call.
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# ── API Testing ───────────────────────────────────────────────────────────────
# Captures all XHR/fetch/API calls made during browser crawl,
# then directly tests each unique endpoint after crawl completes.
# Checks: status codes, response time, security headers, unauthenticated access
# true  = enabled (recommended — no extra dependencies needed)
# false = disabled
API_TESTING=true
# Response time budget in ms — endpoints slower than this flagged as bugs
API_TIMEOUT_MS=3000

# ── Logging ───────────────────────────────────────────────────────────────────
# QUIET  = only PASS/FAIL + final summary
# INFO   = module-level events (default)
# DEBUG  = all prompts, responses, DOM extractions
LOG_LEVEL=INFO

# ── Phase 4: Auto Story Generation ───────────────────────────────────────────
# false = skip entirely (zero performance impact)
# true  = Ollama auto-generates regression stories from TCs after each run
#         Only enable after pilot validates the core crawl+detect loop.
STORY_ENABLED=true

# ── Reporting ─────────────────────────────────────────────────────────────────
ALLURE_RESULTS_DIR=allure-results
ALLURE_REPORT_DIR=allure-report
BUG_REPORTS_DIR=bug_reports
SCREENSHOTS_DIR=screenshots
TC_FILE=generated_test_cases.xlsx
